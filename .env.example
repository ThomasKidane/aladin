# Aladin Extension Configuration
# Copy this file to .env and fill in your values

# Your server URL (where the compatibility API runs)
ALADIN_SERVER_URL=http://localhost:3001

# Gemini API (primary AI for chat)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# OpenClaw Agent Gateway (optional — for agentic tool use)
OPENCLAW_GATEWAY=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
OPENCLAW_AGENT_ID=main

# Auth0 Configuration (secures all agent routes)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=https://api.aladin.finance
