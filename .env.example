# Aladin Extension Configuration
# Copy this file to .env and fill in your values

# Your server URL (where the compatibility API + OpenClaw gateway run)
ALADIN_SERVER_URL=http://localhost:3001

# OpenClaw Gateway (internal, on the server)
OPENCLAW_GATEWAY=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token-here
OPENCLAW_AGENT_ID=main

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=https://api.aladin.finance
AUTH0_CALLBACK_PATH=/auth0

# AWS Bedrock (if using vision/screenshots directly)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
